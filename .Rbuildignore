^.*\.Rproj$
^\.Rproj\.user$
^\.git$
^\.github$
^_pkgdown\.yml$
^docs$
^pkgdown$
^doc$
^Meta$
^README\.Rmd$
^README\.html$
^cran-comments\.md$

# Vignette data artifacts
^vignettes/.*\.loom$
^vignettes/.*\.h5ad$
^vignettes/.*\.h5seurat$
^vignettes/.*\.h5Seurat$
^vignettes/.*\.rds$
^vignettes/.*\.Rds$
^vignettes/.*\.png$
^vignettes/.*\.html$
^vignettes/.*\.R$
^vignettes/.*_files$
^vignettes/\.build\.timestamp$

# Test data (keep shipped samples)
^inst/testdata/.*\.h5seurat$
^inst/testdata/.*\.h5Seurat$
^inst/testdata/.*\.DS_Store$

# Build artifacts
^scConvert_.*\.tar\.gz$
^scConvert_.*\.tgz$
^\.\.Rcheck$
^scConvert\.Rcheck$
^check_output\.log$
^knitted_vignettes$

# Development files
^\.claude$
^SESSION_SUMMARY\.md$
^SCHOLAR_EVALUATION.*\.md$
^codecov\.yml$
^CLAUDE\.md$
^review\.md$
^Rplots\.pdf$

# Large test data (not used by testthat; for local/integration testing only)
^tests/testdata/spatial$

# Vignette data artifacts (generated at build time or not needed)
^vignettes/blobs\.spatialdata\.zarr$

# C CLI artifacts (standalone binary and its Makefile -- not part of R package)
^src/Makefile$
^src/scconvert$
^src/main\.c$
^src/main\.o$
^src/.*\.o$
